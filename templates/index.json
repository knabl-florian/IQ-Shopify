m_color":"#000000"}},"text_7MTqzN":{"type":"text","settings":{"text":"STYLE PREVIEW","text_link":"","text_size":"hd2","font_weight":"font-heading","font_style":"italic","letter_spacing":0,"text_opacity":100,"text_style":"normal","use_custom_color":false,"custom_color":"#000000"}},"text_F6TxHn":{"type":"text","settings":{"text":"FASHION FORECAST","text_link":"","text_size":"hd2","font_weight":"font-heading","font_style":"italic","letter_spacing":0,"text_opacity":100,"text_style":"stroke","use_custom_color":false,"custom_color":"#000000"}}},"block_order":["text_p7XLMj","text_ybabJr","text_7MTqzN","text_F6TxHn"],"disabled":true,"custom_css":[".section--scrolling-promotion {position: relative; padding: 0; z-index: 1; background: none;}",".scrolling-promotion {position: absolute; top: 100%; left: 0; right: 0;}"],"settings":{"color_scheme":"scheme-4","vertical_alignment":"center","direction":"left","pause_on_hover":true,"speed":0.2,"h_spacing":80,"v_spacing":24,"padding_top":0,"padding_bottom":0,"show_divider":false,"divider_layout":"vertical","custom_class":""}},"recently_viewed_products_d6eLk9":{"type":"recently-viewed-products","name":"t:sections.recently-viewed-products.name","settings":{"color_scheme":"","heading":"Kürzlich <em>angeschaut<\/em>","heading_size":"h1","heading_highlight_style":"underline","subheading":"","description":"","limit":8,"columns":4,"column_gap":"medium","row_gap":"inherit","enable_slider":true,"controls_position":"inside","pcard_image_ratio":"","columns_mobile":"2","swipe_on_mobile":true,"padding_top":50,"padding_bottom":50,"show_section_divider":false,"divider_width":"fixed","custom_class":""}},"rich_text_Fj3Xbi":{"type":"rich-text","blocks":{"heading_GtyFMM":{"type":"heading","settings":{"heading":"About <em>IQ Dogsport<\/em>","heading_size":"h1","heading_highlight_style":"underline"}},"subheading_GtNnJJ":{"type":"subheading","settings":{"subheading":"Bekleidung und Trainingszubehör"}},"text_3WBA6j":{"type":"text","settings":{"text":"<p>Wir leben Hundesport. Schon lange. Aber mindestens genau so lange hat immer irgendetwas gefehlt im Traning.  So ist unsere Hundesportweste entstanden. Weil wir da waren, wo Ihr seid. Weil wir das gebraucht haben, was Ihr braucht. Zubehör, das für unser Training und unsere Hunde gemacht ist. <\/p>","text_size":"text-base"}}},"block_order":["heading_GtyFMM","subheading_GtNnJJ","text_3WBA6j"],"custom_css":[],"name":"t:sections.rich-text.presets.name","settings":{"color_scheme":"","content_alignment":"left","padding_top":50,"padding_bottom":30,"show_section_divider":false,"divider_width":"fixed","custom_class":""}},"rich_text_mT3YTH":{"type":"rich-text","blocks":{"subheading_Fbnnt7":{"type":"subheading","settings":{"subheading":"Weste für den Hundesport und Diensthundeführer"}},"text_mCpdik":{"type":"text","settings":{"text":"<p>Schon Conan, der Hund vom IQ Dogsport Gründer Dr. Florian Knabl, hat von Anfang an Vorsitz mit der patentierten Brusttasche unserer Trainingsweste gelernt. 2018 und 2019 hat er dann die FMBB Weltmeisterschaft gewonnen. Kein IQ Dogsport Produkt ist von uns alleine erfunden, sondern es spiegelt die Erfahrung von ganz vielen Hundeführern wieder. Deswegen sind bei unseren Westen und Taschen alle Taschen genau da, wo Ihr sie braucht - ob für Futter, Leckerli Spielzeug, Eure Leinen oder teure Magneten. Unsere patentierte Brusttasche ist ein \"MUST\" für einen geraden Vorsitz, mit der neuen IQ Magnettasche wird die Ausbildung des \"Fuss\" für viele um einiges leichter. Besonders stolz sind wir, dass seit 2019 die Diensthundeführer der Polizei in Deutschland, aber auch zunehmend im Ausland unserer Weste vertrauen.<\/p>","text_size":"text-base"}}},"block_order":["subheading_Fbnnt7","text_mCpdik"],"custom_css":[],"name":"t:sections.rich-text.presets.name","settings":{"color_scheme":"","content_alignment":"left","padding_top":0,"padding_bottom":30,"show_section_divider":false,"divider_width":"fixed","custom_class":""}},"rich_text_RbLd64":{"type":"rich-text","blocks":{"subheading_zQDegN":{"type":"subheading","settings":{"subheading":"Winter- und Regenjacken"}},"text_TPeMb8":{"type":"text","settings":{"text":"<p>Unsere Antwort auf ungemütliche Herbst- und Wintertage ist die Multifunktionsjacke 3.0: ob Ihr eine Winterjacke oder eine Regenjacke braucht: Unsere Jacken präsentieren sich in allen Wetterlagen ganz besonders robust, kratzfest und schmutzunempfindlich. Alle Nähte sind mehrfach vernäht und verriegelt. Egal, was für einen pelzigen Alligator Ihr besitzt .. mit unseren Jacke seid Ihr gut ausgerüstet, denn wie alle unsere Produkte sind die Jacken Hund- und trainingsgerecht: In der großen Rückentasche ist locker Platz für Flexi-, Schleppleinen und große Spielzeuge. Futter verstaut Ihr in den ausknöpfbaren beschichteten Futtertaschen.<\/p>","text_size":"text-base"}}},"block_order":["subheading_zQDegN","text_TPeMb8"],"name":"t:sections.rich-text.presets.name","settings":{"color_scheme":"","content_alignment":"left","padding_top":0,"padding_bottom":30,"show_section_divider":false,"divider_width":"full","custom_class":""}},"multicolumn_mQAQbW":{"type":"multicolumn","blocks":{"column_6be7nJ":{"type":"column","settings":{"show_image":true,"image_width":"full","title":"Sale up to 50% off","heading_size":"h4","text":"<p>Don't miss out! Enjoy discounts of up to 50% off on select items in our limited-time sale.<\/p>","text_size":"text-base","button_label":"Shop now","button_style":"btn--underline","button_link":"","mobile_layout":"inherit"}},"column_m4RcYP":{"type":"column","settings":{"show_image":true,"image_width":"full","title":"Back in stock","heading_size":"h4","text":"<p>Your favorites are back! Shop now to get the newly restocked items before they sell out again.<\/p>","text_size":"text-base","button_label":"Shop now","button_style":"btn--underline","button_link":"","mobile_layout":"inherit"}},"column_bRpkxq":{"type":"column","settings":{"show_image":true,"image_width":"full","title":"Under $99","heading_size":"h4","text