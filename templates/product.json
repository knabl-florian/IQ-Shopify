":{"type":"shopify:\/\/apps\/mini-image-upload\/blocks\/app-block\/019a499d-2f45-732c-96ee-872049547d70","settings":{"product":"{{product}}"}},"buy_buttons":{"type":"buy_buttons","settings":{"show_quantity_selector":true,"show_dynamic_checkout":true,"show_gift_card_recipient":true}},"icon_with_text":{"type":"icon-with-text","settings":{"layout":"horizontal","title_font":"body","title_size":"text-base","icon_1":"package","heading_1":"ab 120€ versandkostenfrei*","icon_2":"arrow-up-left","heading_2":"14 Tage Rückgaberecht","icon_3":"heart","heading_3":"Top Service"}},"pickup_availability":{"type":"pickup_availability","settings":{}},"collapsible-row-1":{"type":"collapsible_tab","settings":{"heading":"Produktbeschreibung","icon":"none","content":"{{ product.description }}","custom_liquid":"","page":"","default_open":false}},"collapsible-row-2":{"type":"collapsible_tab","settings":{"heading":"Fit & Sizing","icon":"none","content":"","custom_liquid":"","page":"{{ product.metafields.custom.grosentabelle.value }}","default_open":false}},"collapsible_tab_8GYHQG":{"type":"collapsible_tab","settings":{"heading":"Bewertungen","icon":"none","content":"","custom_liquid":"<!-- Start of Judge.me code -->\n{% assign has_legacy = false %}{% if product.metafields.judgeme.widget.size > 20 %}{% assign has_legacy = true %}{% endif %}<div style='clear:both'><\/div><div id='judgeme_product_reviews' class='jdgm-widget jdgm-review-widget' data-product-title='{{ product.title | escape }}' data-id='{{ product.id }}' data-product-id='{{ product.id }}' data-widget='review' data-auto-install='false' data-shop-reviews-count='{{ shop.metafields.judgeme.shop_reviews_count | default: 0 | escape }}' data-entry-point='review_widget.js' data-entry-key='review-widget\/main.js'>{% if has_legacy %}<div class='jdgm-legacy-widget-content' style='display: none;'>{{ product.metafields.judgeme.widget }}<\/div>{% endif %}<\/div>{% if product.metafields.judgeme.review_widget_data %}<script>jdgm.data ||= {}; jdgm.data.reviewWidget ||= {}; jdgm.data.reviewWidget[{{ product.id }}] = {{ product.metafields.judgeme.review_widget_data }}<\/script>{% endif %}  \n<!-- End of Judge.me code -->","page":"","default_open":false}},"collapsible-row-3":{"type":"collapsible_tab","settings":{"heading":"Versand & Rückgabe","icon":"none","content":"<h5>Versand innerhalb Deutschlands<\/h5><p>Ab einem Einkaufswert von 130,00 € liefern wir innerhalb Deutschlands <strong>versandkostenfrei<\/strong>, sofern das Höchstgewicht unter 40 kg liegt und die Ware nicht sperrig ist.<br\/>Liegt der Wert unter 130,00 €, betragen die Versandkosten 5,90 €.<br\/>Der erste Umtausch von Waren ist für Sie kostenlos. Die Rücksendung von Waren ohne Umtausch kostet 5,90 €.<\/p><h5>Versand in andere Länder <\/h5><p>Die Versandkosten innerhalb der EU und in andere Länder werden Ihnen <br\/>während des Bestellvorgangs und vor Abschluss der Bestellung angezeigt. <br\/>Die Berechnung der Versandkosten erfolgt je nach Gewicht und Größe. Bei <br\/>Bestellungen innerhalb der EU mit Warenwert über 130,00 € berechnen wir <br\/>reduzierte Versandkosten (z.B. 5,90 € bei einem Sendungsgewicht bis <br\/>5kg). Sperrgutversand ist von dieser Aktion ausgeschlossen.<\/p><p>Die vollständige Regelung finden Sie unter <a href=\"\/pages\/zahlungs-und-versandinformation\" title=\"Zahlungs- und Versandinformation\">Versand- & Zahlungsinformationen<\/a><\/p><p><\/p><h5><strong>Rückgabe<\/strong><\/h5><p><strong>Hinweis auf unsere Rückgaberichtlinien<\/strong><br\/>- Für Rückgabe und Umtausch gilt die gesetzliche Frist von 14 Tagen. <br\/>Diese Frist beginnt am Tag nach der vollständigen Zustellung.<br\/>- Bei einem reinen Rückversand (innerhalb Deutschlands), wenn kein Kaufvertrag zustande kommt, berechnen wir 5,90 Euro Versand.<br\/>- Erfolgt<br\/> eine Teilrückgabe, durch die der ursprüngliche Bestellwert unter die <br\/>Versandfreigrenze von 130 Euro fällt, behalten wir uns vor, die <br\/>regulären Versandkosten in Höhe von 5,90 Euro nachträglich zu berechnen.<br\/>- Bei Rückgabe\/Umtausch im Ausland übernehmen wir keine Versandkosten.<br\/>-<br\/> Der erste Rückversand innerhalb Deutschlands bei Umtausch einer Ware <br\/>ist für Sie kostenlos. Bei jedem weiteren Umtausch werden Retourenkosten<br\/> berechnet.<br\/>- Rücksendeetikett kann nur für Deutschland ausgestellt werden.<br\/>- Die retournierte Ware darf keine Gebrauchsspuren aufweisen oder verschmutzt sein. Es dürfen keine Futterreste in den Taschen sein. Das Warenetikett muss vorhanden sein.<\/p><p><strong>Rückgabe von Trainingshappen und Futter<\/strong><br\/>Gemäß §312 g Abs. 2 Nr. 3 BGB ist die Rückgabe von versiegelter Lebensmittel <strong>ausgeschlossen<\/strong>,<br\/> wenn ihre Versiegelung nach der Lieferung entfernt wurde. Sollten Sie <br\/>fehlerhafte Ware erhalten haben, kontaktieren Sie uns bitte. Wir bemühen<br\/> uns, die bestmögliche Lösung zu finden.<\/p><p><strong>Rückgabe von Büchern<\/strong><br\/>Ein gesetzliches Rückgaberecht für Bücher gibt es <strong>nicht.<\/strong> Die Rückgabemöglichkeit ist <strong>nach<\/strong> <strong>Absprache<\/strong> und <strong>aus reiner Kulanz<\/strong> gestattet. Gegenstand des Kaufvertrages ist der Inhalt, nicht der Datenträger.<\/p><p>Die vollständige Regelung finden Sie unter <a href=\"\/pages\/anfrage-ruckgabe-umtausch\" title=\"Anfrage - Rückgabe \/ Umtausch\">Rückgabe & Umtausch<\/a><\/p>","custom_liquid":"","page":"","default_open":false}},"addons":{"type":"addons","settings":{"show_share":true,"show_ask_question":true}},"sku_LJebPk":{"type":"sku","settings":{"text_style":"body"}},"mini_image_upload_app_block_eLJwBn":{"type":"shopify:\/\/apps\/mini-image-upload\/blocks\/app-block\/019a499d-2f45-732c-96ee-872049547d70","settings":{"product":"{{product}}"}}},"block_order":["title_4AQrFC","judge_me_reviews_preview_badge_f9Nc6i","badges","price","inventory","variant_picker","xboost_bundle_checkbox_upsell_fXe6aY","mini_image_upload_app_block_ztmB3F","buy_buttons","icon_with_text","pick